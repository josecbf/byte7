# ============================================================
# Byte7 Demo — variáveis de ambiente
# ============================================================
# Na fase DEMO, os dados são mockados e nenhuma variável é
# estritamente obrigatória. As chaves abaixo são placeholders
# para quando a aplicação for migrada para uma API real.

# Base URL pública da aplicação (usada em links e SEO)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Modo da camada de dados: "mock" | "api"
# Quando setado para "api", os services passarão a apontar
# para NEXT_PUBLIC_API_BASE_URL (futuro backend real).
NEXT_PUBLIC_DATA_SOURCE=mock

# Base URL da API real (preenchida no futuro)
NEXT_PUBLIC_API_BASE_URL=

# Segredo para assinatura de sessão (quando sair do mock)
SESSION_SECRET=dev-only-change-me
